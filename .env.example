# ==============================================
# AI 电商主图与文案生成工具 - 环境变量模板
# ==============================================
# 复制此文件为 .env.local 并填写实际值
# .env.local 已加入 .gitignore，不会被提交到 GitHub
# ==============================================

# ---------- AI 文本生成（必填） ----------
# OpenAI API Key
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI 模型选择（可选，默认 gpt-4o-mini）
# 可选值：gpt-4o, gpt-4o-mini, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# OpenAI API 基础地址（可选，使用代理或第三方兼容服务时填写）
# 默认：https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1


# ---------- AI 图像生成（可选） ----------
# 如需生成真实主图，选其一即可

# 方案A：DALL-E 3（共用 OPENAI_API_KEY）
DALLE_MODEL=dall-e-3

# 方案B：Stability AI（Stable Diffusion）
# 获取地址：https://platform.stability.ai/account/keys
# STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 方案C：阿里云通义万相（国内推荐）
# 获取地址：https://dashscope.console.aliyun.com/apiKey
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ---------- 服务端配置（可选） ----------
# 应用运行环境
NODE_ENV=development

# 服务端口（默认 3000）
PORT=3000


# ---------- 业务配置（可选） ----------
# 单次生成的主图数量上限
NEXT_PUBLIC_MAX_IMAGE_COUNT=3

# 文案生成超时时间（毫秒）
NEXT_PUBLIC_GENERATE_TIMEOUT=30000
